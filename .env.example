APP_ENV=production
APP_NAME=Sukoon Health API
FRONTEND_ORIGIN=https://sukoonhealth.shop

DATABASE_URL=postgresql+asyncpg://sukoonhealth:<password>@sukoonhealth_sukoonhealth:5432/sukoonhealth

GOOGLE_SHEETS_WEBHOOK_URL=
GOOGLE_SHEETS_WEBHOOK_SECRET=

META_PIXEL_ID=
META_ACCESS_TOKEN=
TIKTOK_PIXEL_CODE=
TIKTOK_ACCESS_TOKEN=
SNAP_PIXEL_ID=
SNAP_ACCESS_TOKEN=

HASH_SALT=

# Backend-only MaxMind minFraud IP screening.
# Blocks clear non-KSA / high-risk IPs when ENABLE_IP_FRAUD_CHECK=true.
MAXMIND_ACCOUNT_ID=
MAXMIND_LICENSE_KEY=
ENABLE_IP_FRAUD_CHECK=false
MAXMIND_RISK_SCORE_THRESHOLD=25
MAXMIND_ALLOWED_COUNTRY=SA
WHITELISTED_PHONES=
